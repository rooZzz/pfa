{
  "name": "pfa-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Personal finance assistant MCP server",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && npm run build:ui",
    "build:ui": "node build-ui.mjs",
    "start": "npm run build && tsx http.ts",
    "start:http": "tsx http.ts",
    "dev": "concurrently -k -n ui,server \"cross-env NODE_ENV=development node build-ui.mjs --watch\" \"tsx http.ts\"",
    "dev:auth": "npm run dev:auth:gen-key && cross-env PFA_DIR=.localdev PFA_DEV_ENV=config/localhost-auth.env tsx http.ts",
    "dev:auth:gen-key": "cross-env PFA_DIR=.localdev PFA_DEV_ENV=config/localhost-auth.env tsx scripts/gen-signing-key.ts",
    "dev:auth:enroll": "cross-env PFA_DIR=.localdev PFA_DEV_ENV=config/localhost-auth.env tsx scripts/enroll-passkey.ts",
    "inspect": "mcp-inspector",
    "monzo:auth": "tsx scripts/monzo-auth.ts",
    "gen-signing-key": "tsx scripts/gen-signing-key.ts",
    "enroll-passkey": "tsx scripts/enroll-passkey.ts",
    "mint-token": "tsx scripts/mint-token.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.0.0",
    "duckdb": "^1.2.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "kysely": "^0.29.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.0.0"
  }
}
